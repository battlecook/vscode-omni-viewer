          {
            "filenamePattern": "*.mf4"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.jsonViewer",
        "displayName": "JSON Viewer",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.yamlViewer",
        "displayName": "YAML Viewer",
        "selector": [
          {
            "filenamePattern": "*.yaml"
          },
          {
            "filenamePattern": "*.yml"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.jsonlViewer",
        "displayName": "JSONL Viewer",
        "selector": [
          {
            "filenamePattern": "*.jsonl"
          },
          {
            "filenamePattern": "*.ndjson"
          },
          {
            "filenamePattern": "*.jsonlines"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.tomlViewer",
        "displayName": "TOML Viewer",
        "selector": [
          {
            "filenamePattern": "*.toml"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.markdownViewer",
        "displayName": "Markdown Viewer",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.mermaidViewer",
        "displayName": "Mermaid Viewer",
        "selector": [
          {
            "filenamePattern": "*.mmd"
          },
          {
            "filenamePattern": "*.mermaid"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.plantumlViewer",
        "displayName": "PlantUML Viewer",
        "selector": [
          {
            "filenamePattern": "*.puml"
          },
          {
            "filenamePattern": "*.plantuml"
          },
          {
            "filenamePattern": "*.iuml"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.parquetViewer",
        "displayName": "Parquet Viewer",
        "selector": [
          {
            "filenamePattern": "*.parquet"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.hwpViewer",
        "displayName": "HWP Viewer",
        "selector": [
          {
            "filenamePattern": "*.hwp"
          },
          {
            "filenamePattern": "*.hwpx"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.psdViewer",
        "displayName": "PSD Viewer",
