{
  "name": "omni-viewer",
  "displayName": "omni-viewer",
  "publisher": "battlecook",
  "description": "A VSCode extension for viewing audio, image, video, archive, csv, DBC, ARXML, A2L, ASC, BLF, MF4, excel, word, powerpoint, parquet, jsonl, yaml, toml, markdown, mermaid, PlantUML, hwp, PSD and PDF files",
  "version": "0.30.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/battlecook/vscode-omni-viewer.git"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/battlecook"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "media",
    "audio",
    "video",
    "image",
    "archive",
    "zip",
    "tar",
    "gz",
    "PDF",
    "CSV",
    "DBC",
    "ARXML",
    "A2L",
    "ASC",
    "BLF",
    "MF4",
    "CAN",
    "Excel",
    "xlsx",
    "xls",
    "Word",
    "docx",
    "PowerPoint",
    "pptx",
    "JSONL",
    "JSON",
    "YAML",
    "TOML",
    "Markdown",
    "Mermaid",
    "PlantUML",
    "Parquet",
    "HWP",
    "PSD",
    "한글",
    "viewers",
    "viewer"
  ],
  "icon": "img/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "omni-viewer.archiveViewer",
        "displayName": "Archive Viewer",
        "selector": [
          {
            "filenamePattern": "*.zip"
          },
          {
            "filenamePattern": "*.rar"
          },
          {
            "filenamePattern": "*.7z"
          },
          {
            "filenamePattern": "*.dmg"
          },
          {
            "filenamePattern": "*.jar"
          },
          {
            "filenamePattern": "*.apk"
          },
          {
            "filenamePattern": "*.tar"
          },
          {
            "filenamePattern": "*.tgz"
          },
          {
            "filenamePattern": "*.tar.gz"
          },
          {
            "filenamePattern": "*.tbz2"
          },
          {
            "filenamePattern": "*.tar.bz2"
          },
          {
            "filenamePattern": "*.txz"
          },
          {
            "filenamePattern": "*.tar.xz"
          },
          {
            "filenamePattern": "*.gz"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.audioViewer",
        "displayName": "Audio Viewer",
        "selector": [
          {
            "filenamePattern": "*.mp3"
          },
          {
            "filenamePattern": "*.wav"
          },
          {
            "filenamePattern": "*.pcm"
          },
          {
            "filenamePattern": "*.aiff"
          },
          {
            "filenamePattern": "*.aif"
          },
          {
            "filenamePattern": "*.aifc"
          },
          {
            "filenamePattern": "*.amr"
          },
          {
            "filenamePattern": "*.awb"
          },
          {
            "filenamePattern": "*.ogg"
          },
          {
            "filenamePattern": "*.flac"
          },
          {
            "filenamePattern": "*.ac3"
          },
          {
            "filenamePattern": "*.aac"
          },
          {
            "filenamePattern": "*.m4a"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.videoViewer",
        "displayName": "Video Viewer",
        "selector": [
          {
            "filenamePattern": "*.mp4"
          },
          {
            "filenamePattern": "*.mts"
          },
          {
            "filenamePattern": "*.m2ts"
          },
          {
            "filenamePattern": "*.avi"
          },
          {
            "filenamePattern": "*.mov"
          },
          {
            "filenamePattern": "*.wmv"
          },
          {
            "filenamePattern": "*.flv"
          },
          {
            "filenamePattern": "*.webm"
          },
          {
            "filenamePattern": "*.mkv"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.imageViewer",
        "displayName": "Image Viewer",
        "selector": [
          {
            "filenamePattern": "*.jpg"
          },
          {
            "filenamePattern": "*.jpeg"
          },
          {
            "filenamePattern": "*.png"
          },
          {
            "filenamePattern": "*.gif"
          },
          {
            "filenamePattern": "*.bmp"
          },
          {
            "filenamePattern": "*.webp"
          },
          {
            "filenamePattern": "*.svg"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.csvViewer",
        "displayName": "CSV Viewer",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.dbcViewer",
        "displayName": "DBC Viewer",
        "selector": [
          {
            "filenamePattern": "*.dbc"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.arxmlViewer",
        "displayName": "ARXML Viewer",
        "selector": [
          {
            "filenamePattern": "*.arxml"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.a2lViewer",
        "displayName": "A2L Viewer",
        "selector": [
          {
            "filenamePattern": "*.a2l"
          },
          {
            "filenamePattern": "*.A2L"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.ascViewer",
        "displayName": "ASC Viewer",
        "selector": [
          {
            "filenamePattern": "*.asc"
