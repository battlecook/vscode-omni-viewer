  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build:wasm": "cd src/wasm && bash build.sh",
    "sync:rhwp": "node scripts/sync-rhwp-assets.js",
    "compile": "npm run sync:rhwp && webpack --mode production",
    "watch": "npm run sync:rhwp && webpack --mode development --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "postinstall": "npm run sync:rhwp"
  },
