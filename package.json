    "menus": {
      "editor/title": [
        {
          "command": "omni-viewer.refresh",
          "when": "activeCustomEditorId =~ /^omni-viewer\\./",
          "group": "navigation@1"
        },
        {
          "command": "omni-viewer.shareFile",
          "when": "activeCustomEditorId =~ /^omni-viewer\\./",
          "group": "navigation@2"
        },
        {
          "command": "omni-viewer.openSharedLink",
          "when": "activeCustomEditorId =~ /^omni-viewer\\./",
          "group": "navigation@3"
        }
      ],
      "explorer/context": [
        {
          "command": "omni-viewer.openArchiveViewer",
          "when": "resourceExtname == '.zip' || resourceExtname == '.rar' || resourceExtname == '.7z' || resourceExtname == '.dmg' || resourceExtname == '.jar' || resourceExtname == '.apk' || resourceExtname == '.tar' || resourceExtname == '.tgz' || resourceExtname == '.tbz2' || resourceExtname == '.bz2' || resourceExtname == '.txz' || resourceExtname == '.xz' || resourceExtname == '.gz'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openAudioViewer",
          "when": "resourceExtname == '.mp3' || resourceExtname == '.wav' || resourceExtname == '.pcm' || resourceExtname == '.aiff' || resourceExtname == '.aif' || resourceExtname == '.aifc' || resourceExtname == '.amr' || resourceExtname == '.awb' || resourceExtname == '.ogg' || resourceExtname == '.flac' || resourceExtname == '.ac3' || resourceExtname == '.aac' || resourceExtname == '.m4a'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openVideoViewer",
          "when": "resourceExtname == '.mp4' || resourceExtname == '.mts' || resourceExtname == '.m2ts' || resourceExtname == '.avi' || resourceExtname == '.mov' || resourceExtname == '.wmv' || resourceExtname == '.flv' || resourceExtname == '.webm' || resourceExtname == '.mkv'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openImageViewer",
          "when": "resourceExtname == '.jpg' || resourceExtname == '.jpeg' || resourceExtname == '.png' || resourceExtname == '.gif' || resourceExtname == '.bmp' || resourceExtname == '.webp' || resourceExtname == '.svg'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openCsvViewer",
          "when": "resourceExtname == '.csv' || resourceExtname == '.tsv'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openDbcViewer",
          "when": "resourceExtname == '.dbc'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openArxmlViewer",
          "when": "resourceExtname == '.arxml'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openA2lViewer",
          "when": "resourceExtname == '.a2l'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openAscViewer",
          "when": "resourceExtname == '.asc'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openBlfViewer",
          "when": "resourceExtname == '.blf'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openMf4Viewer",
          "when": "resourceExtname == '.mf4'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openJsonViewer",
          "when": "resourceExtname == '.json'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openYamlViewer",
          "when": "resourceExtname == '.yaml' || resourceExtname == '.yml'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openJsonlViewer",
          "when": "resourceExtname == '.jsonl' || resourceExtname == '.ndjson' || resourceExtname == '.jsonlines'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openTomlViewer",
          "when": "resourceExtname == '.toml'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openMarkdownViewer",
          "when": "resourceExtname == '.md' || resourceExtname == '.markdown'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openMermaidViewer",
          "when": "resourceExtname == '.mmd' || resourceExtname == '.mermaid'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openPlantumlViewer",
          "when": "resourceExtname == '.puml' || resourceExtname == '.plantuml' || resourceExtname == '.iuml'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openParquetViewer",
          "when": "resourceExtname == '.parquet'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openHwpViewer",
          "when": "resourceExtname == '.hwp' || resourceExtname == '.hwpx'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openPsdViewer",
          "when": "resourceExtname == '.psd'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openExcelViewer",
          "when": "resourceExtname == '.xlsx' || resourceExtname == '.xls'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openWordViewer",
          "when": "resourceExtname == '.docx' || resourceExtname == '.doc'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openPptViewer",
          "when": "resourceExtname == '.pptx' || resourceExtname == '.ppt'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.shareFile",
          "when": "!explorerResourceIsFolder",
          "group": "7_modification"
        }
      ]
    },
