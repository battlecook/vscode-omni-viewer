{
  "name": "omni-viewer",
  "displayName": "omni-viewer",
  "publisher": "battlecook",
  "description": "A VSCode extension for viewing audio, image, video, archive, csv, excel, word, powerpoint, parquet, jsonl, hwp, PSD and PDF files",
  "version": "0.17.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/battlecook/vscode-omni-viewer.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "media",
    "audio",
    "video",
    "image",
    "archive",
    "zip",
    "tar",
    "gz",
    "PDF",
    "CSV",
    "Excel",
    "xlsx",
    "xls",
    "Word",
    "docx",
    "PowerPoint",
    "pptx",
    "JSONL",
    "JSON",
    "Parquet",
    "HWP",
    "PSD",
    "한글",
    "viewers",
    "viewer"
  ],
  "icon": "img/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "omni-viewer.archiveViewer",
        "displayName": "Archive Viewer",
        "selector": [
          {
            "filenamePattern": "*.zip"
          },
          {
            "filenamePattern": "*.jar"
          },
          {
            "filenamePattern": "*.apk"
          },
          {
            "filenamePattern": "*.tar"
          },
          {
            "filenamePattern": "*.tgz"
          },
          {
            "filenamePattern": "*.tar.gz"
          },
          {
            "filenamePattern": "*.gz"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.audioViewer",
        "displayName": "Audio Viewer",
        "selector": [
          {
            "filenamePattern": "*.mp3"
          },
          {
            "filenamePattern": "*.wav"
          },
          {
            "filenamePattern": "*.aiff"
          },
          {
            "filenamePattern": "*.aif"
          },
          {
            "filenamePattern": "*.aifc"
          },
          {
            "filenamePattern": "*.amr"
          },
          {
            "filenamePattern": "*.awb"
          },
          {
            "filenamePattern": "*.ogg"
          },
          {
            "filenamePattern": "*.flac"
          },
          {
            "filenamePattern": "*.ac3"
          },
          {
            "filenamePattern": "*.aac"
          },
          {
            "filenamePattern": "*.m4a"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.videoViewer",
        "displayName": "Video Viewer",
        "selector": [
          {
            "filenamePattern": "*.mp4"
          },
          {
            "filenamePattern": "*.mts"
          },
          {
            "filenamePattern": "*.m2ts"
          },
          {
            "filenamePattern": "*.avi"
          },
          {
            "filenamePattern": "*.mov"
          },
          {
            "filenamePattern": "*.wmv"
          },
          {
            "filenamePattern": "*.flv"
          },
          {
            "filenamePattern": "*.webm"
          },
          {
            "filenamePattern": "*.mkv"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.imageViewer",
        "displayName": "Image Viewer",
        "selector": [
          {
            "filenamePattern": "*.jpg"
          },
          {
            "filenamePattern": "*.jpeg"
          },
          {
            "filenamePattern": "*.png"
          },
          {
            "filenamePattern": "*.gif"
          },
          {
            "filenamePattern": "*.bmp"
          },
          {
            "filenamePattern": "*.webp"
          },
          {
            "filenamePattern": "*.svg"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.csvViewer",
        "displayName": "CSV Viewer",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.jsonlViewer",
        "displayName": "JSONL Viewer",
        "selector": [
          {
            "filenamePattern": "*.jsonl"
          },
          {
            "filenamePattern": "*.ndjson"
          },
          {
            "filenamePattern": "*.jsonlines"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "omni-viewer.parquetViewer",
        "displayName": "Parquet Viewer",
        "selector": [
          {
            "filenamePattern": "*.parquet"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.hwpViewer",
        "displayName": "HWP Viewer",
        "selector": [
          {
            "filenamePattern": "*.hwp"
          },
          {
            "filenamePattern": "*.hwpx"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.psdViewer",
        "displayName": "PSD Viewer",
        "selector": [
          {
            "filenamePattern": "*.psd"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.excelViewer",
        "displayName": "Excel Viewer",
        "selector": [
          {
            "filenamePattern": "*.xlsx"
          },
          {
            "filenamePattern": "*.xls"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.wordViewer",
        "displayName": "Word Viewer",
        "selector": [
          {
            "filenamePattern": "*.docx"
          },
          {
            "filenamePattern": "*.doc"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.pdfViewer",
        "displayName": "PDF Editor",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.pptViewer",
        "displayName": "PowerPoint Viewer",
        "selector": [
          {
            "filenamePattern": "*.ppt"
          },
          {
            "filenamePattern": "*.pptx"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "omni-viewer.openArchiveViewer",
          "when": "resourceExtname == '.zip' || resourceExtname == '.jar' || resourceExtname == '.apk' || resourceExtname == '.tar' || resourceExtname == '.tgz' || resourceExtname == '.gz'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openAudioViewer",
          "when": "resourceExtname == '.mp3' || resourceExtname == '.wav' || resourceExtname == '.aiff' || resourceExtname == '.aif' || resourceExtname == '.aifc' || resourceExtname == '.amr' || resourceExtname == '.awb' || resourceExtname == '.ogg' || resourceExtname == '.flac' || resourceExtname == '.ac3' || resourceExtname == '.aac' || resourceExtname == '.m4a'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openVideoViewer",
          "when": "resourceExtname == '.mp4' || resourceExtname == '.mts' || resourceExtname == '.m2ts' || resourceExtname == '.avi' || resourceExtname == '.mov' || resourceExtname == '.wmv' || resourceExtname == '.flv' || resourceExtname == '.webm' || resourceExtname == '.mkv'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openImageViewer",
          "when": "resourceExtname == '.jpg' || resourceExtname == '.jpeg' || resourceExtname == '.png' || resourceExtname == '.gif' || resourceExtname == '.bmp' || resourceExtname == '.webp' || resourceExtname == '.svg'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openCsvViewer",
          "when": "resourceExtname == '.csv' || resourceExtname == '.tsv'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openJsonlViewer",
          "when": "resourceExtname == '.jsonl' || resourceExtname == '.ndjson' || resourceExtname == '.jsonlines'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openParquetViewer",
          "when": "resourceExtname == '.parquet'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openHwpViewer",
          "when": "resourceExtname == '.hwp' || resourceExtname == '.hwpx'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openPsdViewer",
          "when": "resourceExtname == '.psd'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openExcelViewer",
          "when": "resourceExtname == '.xlsx' || resourceExtname == '.xls'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openWordViewer",
          "when": "resourceExtname == '.docx' || resourceExtname == '.doc'",
          "group": "navigation"
        },
        {
          "command": "omni-viewer.openPptViewer",
          "when": "resourceExtname == '.pptx' || resourceExtname == '.ppt'",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "omni-viewer.openArchiveViewer",
        "title": "Open with Archive Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openAudioViewer",
        "title": "Open with Audio Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openVideoViewer",
        "title": "Open with Video Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openImageViewer",
        "title": "Open with Image Editor",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openCsvViewer",
        "title": "Open with CSV Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openJsonlViewer",
        "title": "Open with JSONL Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openParquetViewer",
        "title": "Open with Parquet Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openHwpViewer",
        "title": "Open with HWP Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openPsdViewer",
        "title": "Open with PSD Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openExcelViewer",
        "title": "Open with Excel Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openWordViewer",
        "title": "Open with Word Viewer",
        "category": "Omni Viewer"
      },
      {
        "command": "omni-viewer.openPptViewer",
        "title": "Open with PowerPoint Viewer",
        "category": "Omni Viewer"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@types/jest": "^29.5.14",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "babel-loader": "^9.1.3",
    "eslint": "^8.39.0",
    "jest": "^29.7.0",
    "path-browserify": "^1.0.1",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.0.4",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "ag-psd": "^30.1.0",
    "docx-preview": "^0.3.7",
    "hwp.js": "^0.0.3",
    "hyparquet": "^1.21.0",
    "jszip": "^3.10.1",
    "music-metadata": "^11.8.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "wavesurfer.js": "^7.12.3",
    "xlsx": "^0.18.5"
  }
}
