            "filenamePattern": "*.xls"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.wordViewer",
        "displayName": "Word Viewer",
        "selector": [
          {
            "filenamePattern": "*.docx"
          },
          {
            "filenamePattern": "*.doc"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "omni-viewer.pdfViewer",
        "displayName": "PDF Editor",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
